# GENERAL & ANIMATIONS (общие настройки)
general {
    hide_cursor = false
    ignore_empty_input = true
}

animations {
    enabled = true
    bezier = linear, 1, 1, 0, 0
    animation = fadeIn, 1, 5, linear
    animation = fadeOut, 1, 5, linear
}

# --- МОНИТОР 1 (LAPTOP eDP-1, scale 2) ---

background {
    monitor = eDP-1
    path = {{wallpaper}}
    blur_passes = 2
    contrast = 0.8916
    brightness = 0.8172
    vibrancy = 0.1696
    vibrancy_darkness = 0.0
}

label {
    monitor = eDP-1
    text = cmd[update:1000] echo "$(date +"%-I:%M%p")"
    color = rgba({{foreground | rgb}}, 0.75)
    font_size = 140
    font_family = SF Pro Display Bold
    position = 0, -200
    halign = center
    valign = top
}


label {
    monitor = eDP-1
    text = $LAYOUT
    color = rgba({{foreground | rgb}}, 0.65)
    font_size = 25
    font_family = system-ui
    position = 0, -420
    halign = center
    valign = center
}

label {
    monitor = eDP-1
    text = cmd[update:1000] echo "<span>$(date '+%A, %d %B')</span>"
    color = rgba({{foreground | rgb}}, 0.65)
    font_size = 35
    font_family = system-ui
    position = 0, 400
    halign = center
    valign = center
}

image {
    monitor = eDP-1
    path = ~/Pictures/pfp/current_pfp.jpg
    size = 250
    rounding = -1
    border_size = 4
    border_color = rgba({{color2 | rgb}}, 1)
    position = 0, -100
    halign = center
    valign = center
}

label {
    monitor = eDP-1
    text = Hello, $USER
    color = rgba({{foreground | rgb}}, 0.65)
    font_size = 35
    font_family = system-ui
    position = 0, -260
    halign = center
    valign = center
}

input-field {
    monitor = eDP-1
    size = 320, 70
    outline_thickness = 2
    dots_size = 0.2
    dots_spacing = 0.2
    dots_center = true
    outer_color = rgba({{color0 | rgb}}, 0)
    inner_color = rgba({{color0 | rgb}}, 0.35)
    font_color = rgba({{foreground | rgb}}, 1)
    fade_on_empty = false
    font_family = system-ui
    placeholder_text = <i><span foreground="##{{foreground | strip}}99">$FPRINTPROMPT</span></i>
    hide_input = false
    position = 0, -340
    halign = center
    valign = center
}

auth {
    fingerprint {
        enabled = true
        retry_delay = 500
        ready_message = Touch ID or Password
        present_message = Scanning...
    }
}


