decoration {
    rounding = 10
    rounding_power = 2

    # Change transparency of focused and unfocused windows
    active_opacity = 1.0
    inactive_opacity = 0.95

    blur {
        enabled = true
        size = 3
        passes = 1
        new_optimizations = false
        vibrancy = 0.1696
    }

    shadow {
        # strip removes '#' if it exists
        color = 0xff{{color1 | strip}}
        color_inactive = 0x44{{color1 | strip}}
    }
}

general {
    border_size = 2
    col.active_border = 0xee{{color1 | strip}} 0xee{{color2 | strip}} 45deg
    col.inactive_border = 0xcc{{color0 | strip}}
}
